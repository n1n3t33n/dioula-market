# ---- Dioula Market : variables d'environnement (MODÈLE) ----
# Copie ce fichier en .env  ( cp .env.example .env )  puis remplis les valeurs.
# Le vrai .env est ignoré par git. Ne JAMAIS commit de clés réelles.

# Project URL  (Supabase > Project Settings > Data API > Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co

# Clé publique anon  (Supabase > Project Settings > API Keys > anon public)
# Cette clé est SAFE côté client (protégée par les RLS policies).
SUPABASE_ANON_KEY=eyJhbGciOi...votre_cle_anon...

# ⚠️  NE METS JAMAIS la clé service_role ici ni dans l'application Flutter.
#     Elle contourne toutes les RLS. Réserve-la à un usage serveur sécurisé.
